{
   "name": "swiftmail",
   "private": true,
   "version": "0.0.0",
   "type": "module",
   "scripts": {
      "dev": "VITE_COMMIT_ID=$(git rev-parse --short HEAD) vite",
      "build": "VITE_COMMIT_ID=$(git rev-parse --short HEAD)  tsc -b && vite build",
      "preview": "VITE_COMMIT_ID=$(git rev-parse --short HEAD) vite preview",
      "lint": "eslint .",
      "pretty": "prettier --write ./src/**/*.{ts,tsx,tsx}",
      "ts-check": "tsc --noEmit"
   },
   "dependencies": {
      "react": "^18.3.1",
      "react-dom": "^18.3.1",
      "tinydate": "^1.3.0"
   },
   "devDependencies": {
      "@eslint/js": "^9.11.1",
      "@types/node": "^22.7.6",
      "@types/react": "^18.3.10",
      "@types/react-dom": "^18.3.0",
      "@vitejs/plugin-react": "^4.3.2",
      "autoprefixer": "^10.4.20",
      "eslint": "^9.11.1",
      "eslint-plugin-react-hooks": "^5.1.0-rc.0",
      "eslint-plugin-react-refresh": "^0.4.12",
      "globals": "^15.9.0",
      "postcss": "^8.4.47",
      "prettier": "^3.3.3",
      "tailwindcss": "^3.4.14",
      "typescript": "^5.5.3",
      "typescript-eslint": "^8.7.0",
      "vite": "^5.4.8",
      "vite-tsconfig-paths": "^5.0.1"
   }
}